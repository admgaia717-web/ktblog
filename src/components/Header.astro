---
const links = [
  { href: '/', label: 'Home' },
  { href: '/archive', label: 'Archive' },
  { href: '/categories', label: 'Categories' },
  { href: '/about', label: 'About' },
];
const currentPath = Astro.url.pathname;
---
<header class="border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-md sticky top-0 z-50">
  <nav class="mx-auto max-w-4xl px-5 py-5 flex items-center justify-between">
    <a href="/" class="font-[var(--font-serif)] text-xl font-bold tracking-tight hover:text-[var(--color-accent)] transition-colors">
      KTblog
    </a>
    <ul class="flex gap-6 text-sm">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'hover:text-[var(--color-accent)] transition-colors',
              currentPath === href && 'text-[var(--color-accent)]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
