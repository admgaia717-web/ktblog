---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { groupPostsByCategory } from '../../lib/categories';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const categoryGroups = groupPostsByCategory(allPosts);

  return categoryGroups.map((group) => ({
    params: { name: group.name },
    props: {
      groupName: group.name,
      posts: group.posts,
      totalPosts: allPosts.length,
    },
  }));
}

const { groupName, posts, totalPosts } = Astro.props;
---
<BaseLayout title={`${groupName} | KTblog`}>
  <header class="mb-12 space-y-3">
    <p class="text-xs tracking-[0.25em] uppercase text-[var(--color-accent)]">
      <a href="/categories" class="hover:text-[var(--color-accent)] transition-colors">Categories</a>
      <span class="mx-2">/</span>
      {groupName}
    </p>
    <h1 class="font-[var(--font-serif)] text-4xl md:text-5xl font-bold tracking-tight">{groupName}</h1>
    <p class="text-[var(--color-text-muted)]">{posts.length}件の記事 · {totalPosts}件中</p>
  </header>

  <div class="grid md:grid-cols-2 gap-10">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </div>
</BaseLayout>
