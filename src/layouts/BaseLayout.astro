---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description = 'KTblog - 思想と記録のアーカイブ。AI、文化、デザイン、戦略について静かに深く書き留める。',
  image,
  url,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'KT',
  category,
  tags = [],
  noindex = false,
} = Astro.props;

// og:image の連結バグ対策：相対パスは Astro.site をベースに絶対URL化
const siteUrl = Astro.site ?? new URL('https://tsurumai-nara.com');
const canonicalUrl = url
  ? new URL(url, siteUrl).toString()
  : new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image
  ? (image.startsWith('http://') || image.startsWith('https://'))
    ? image
    : new URL(image, siteUrl).toString()
  : new URL('/assets/ogp-default.png', siteUrl).toString();
const siteName = 'KTblog';
const locale = 'ja_JP';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="670" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {type === 'article' && author && (
      <meta property="article:author" content={author} />
    )}
    {type === 'article' && category && (
      <meta property="article:section" content={category} />
    )}
    {type === 'article' && tags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- JSON-LD 構造化データ（Page 単位の最小構造） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': type === 'article' ? 'Article' : 'WebSite',
      headline: title,
      description: description,
      url: canonicalUrl,
      image: ogImage,
      ...(type === 'article' && {
        datePublished: publishedTime,
        dateModified: modifiedTime ?? publishedTime,
        author: { '@type': 'Person', name: author },
        publisher: {
          '@type': 'Organization',
          name: siteName,
          url: siteUrl.toString(),
        },
        ...(category && { articleSection: category }),
        ...(tags.length > 0 && { keywords: tags.join(', ') }),
      }),
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&family=Shippori+Mincho:wght@700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)] font-[var(--font-sans)] transition-colors duration-300">
    <Header />
    <main class="mx-auto max-w-4xl px-5 py-10 md:py-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
